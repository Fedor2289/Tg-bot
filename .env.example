BOT_TOKEN=ваш_токен_здесь
WEATHER_API_KEY=ваш_ключ_openweathermap
ADMIN_ID=ваш_telegram_id

# ИИ — выбери один или оба
GROQ_API_KEY=ваш_groq_ключ
CEREBRAS_API_KEY=ваш_cerebras_ключ

# Какой бэкенд: groq | cerebras | auto
AI_BACKEND=auto

# Имя ИИ-личности
AI_NAME=Наблюдатель

# Параметры хоррора
STAGE_SEC=900
HORROR_DELAY_SEC=45
SPAM_INTERVAL=8

# Авто-голосовые в группе
GROUP_AUTO_VOICE=1

# Путь к БД (на Railway — папка /data/horror.db)
DB_PATH=horror.db
